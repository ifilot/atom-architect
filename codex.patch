new file mode 100644
index 0000000000000000000000000000000000000000..4ec8b869a17bf2d130367d9c458f3d3272e0006a
--- /dev/null
+++ b/src/data/neb_calculation_loader.h
@@ -0,0 +1,21 @@
+#pragma once
+
+#include <QString>
+
+#include <memory>
+#include <vector>
+
+#include "structure.h"
+
+class NebCalculationLoader {
+public:
+    bool load(const QString& root_directory, QString* error_message = nullptr);
+
+    const std::vector<std::shared_ptr<Structure>>& structures() const {
+        return structures_;
+    }
+
+private:
+    std::vector<std::shared_ptr<Structure>> structures_;
+};
